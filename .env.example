# nanohome environment variables.
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored — never commit secrets. Required vars with no value below will
# cause `next build` / `next dev` to fail at the zod parse in
# `src/lib/env.ts` until they are set.

# ---------------------------------------------------------------------------
# PUBLIC — safe to expose to the browser (prefixed NEXT_PUBLIC_)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Optional: Microsoft Clarity analytics session id.
# NEXT_PUBLIC_CLARITY_ID=

# Optional: Axiom Next.js logging/telemetry.
# NEXT_PUBLIC_AXIOM_DATASET=
# NEXT_PUBLIC_AXIOM_TOKEN=

# ---------------------------------------------------------------------------
# SERVER-ONLY — never prefixed, never imported by client components.
# ---------------------------------------------------------------------------
# Supabase service role key. Bypasses RLS. Only import via
# src/lib/supabase/admin.ts (which has `import "server-only"`).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Shared secret protecting cron/route handler endpoints.
CRON_SECRET=your_cron_secret_here

# ---------------------------------------------------------------------------
# AMIS — server-only third-party ERP integration (all optional until wired)
# ---------------------------------------------------------------------------
# AMIS CRM Connect v2. The app exchanges these credentials for a short-lived
# Bearer token, then makes GET-only business-data requests.
# AMIS_API_BASE_URL=https://crmconnect.misa.vn
# AMIS_CLIENT_ID=
# AMIS_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# ANALYTICS — optional, public (see PUBLIC block above)
# ---------------------------------------------------------------------------
